{
    "name": "free-nextjs-admin-dashboard",
    "version": "1.3.5",
    "private": true,
  "scripts": {
    "dev": "next dev",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "next build",
    "build:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next build",
    "build:slim": "set NEXT_DISABLE_WEBPACK_CACHE=1&& next build",
    "postbuild": "node -e \"require('fs').rmSync('.next/cache',{recursive:true,force:true})\"",
    "start": "next start",
    "lint": "next lint",
    "build:legacy": "next build",
    "build:fast": "set NEXT_TELEMETRY_DISABLED=1&& set NODE_OPTIONS=--max-old-space-size=4096&& next build"
  },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^6.6.0",
        "@fortawesome/free-solid-svg-icons": "^6.6.0",
        "@fortawesome/react-fontawesome": "^0.2.2",
        "@types/jwt-decode": "^2.2.1",
        "@zxing/browser": "^0.1.5",
        "apexcharts": "^4.0.0",
        "axios": "^1.7.7",
        "exceljs": "^4.4.0",
        "flatpickr": "^4.6.13",
        "html2canvas": "^1.4.1",
        "html5-qrcode": "^2.3.8",
        "jsonwebtoken": "^9.0.2",
        "jsvectormap": "^1.6.0",
        "jwt-decode": "^4.0.0",
        "lucide-react": "^0.541.0",
        "moment": "^2.30.1",
        "moment-timezone": "^0.6.0",
        "next": "^14.2.35",
        "next-qrcode": "^2.5.1",
        "qrcode.react": "^4.2.0",
        "react": "^18",
