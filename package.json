        "react-barcode": "^1.6.1",
        "react-beautiful-dnd": "^13.1.1",
        "react-data-table-component": "^7.6.2",
        "react-datepicker": "^8.3.0",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dom": "^18",
        "react-draggable": "^4.4.6",
        "react-dropzone": "^14.3.8",
        "react-easy-crop": "^5.4.1",
        "react-icons": "^5.3.0",
