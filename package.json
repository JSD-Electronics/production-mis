        "react-quill": "^2.0.0",
        "react-rnd": "^10.5.2",
        "react-select": "^5.10.2",
        "react-tabs": "^6.1.0",
        "react-toastify": "^10.0.5",
        "react-tooltip": "^5.28.1",
        "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
