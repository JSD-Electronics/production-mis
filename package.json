        "@types/react-dnd-html5-backend": "^3.0.2",
        "@types/react-dom": "^18",
        "autoprefixer": "^10.0.1",
        "eslint": "^8.57.0",
        "eslint-config-next": "^14.2.35",
        "postcss": "^8",
        "prettier": "^3.2.5",
        "prettier-plugin-tailwindcss": "^0.5.11",
        "tailwindcss": "^3.4.1",
        "typescript": "^5"
